{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chromalab.local/schemas/benchmark/runtime-calibration-closure-record.schema.json",
  "title": "ChromaLab Runtime Calibration Closure Record",
  "description": "Shadow/parity record for R11 calibration closure using R10 runtime OCR anchor bridge rows.",
  "type": "object",
  "required": [
    "schemaVersion",
    "recordId",
    "fixtureId",
    "sourceId",
    "sourceKind",
    "productionImpact",
    "runtimeReadiness",
    "expectedGraphCount",
    "detectedGraphCount",
    "graphCountScore",
    "expectedLayoutClass",
    "predictedLayoutClass",
    "layoutClassScore",
    "runtimeCalibrationClosure",
    "calibrationClosureReport",
    "references",
    "evidence",
    "promotionDecision",
    "notes"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "chromalab.benchmark.runtime_calibration_closure_record.v1"
    },
    "recordId": {
      "type": "string",
      "minLength": 1
    },
    "fixtureId": {
      "type": "string",
      "minLength": 1
    },
    "sourceId": {
      "type": "string",
      "minLength": 1
    },
    "sourceKind": {
      "const": "RUNTIME_CALIBRATION_CLOSURE_SHADOW_CANDIDATE"
    },
    "productionImpact": {
      "const": "NONE_SHADOW_ONLY"
    },
    "runtimeReadiness": {
      "type": "string",
      "minLength": 1
    },
    "expectedGraphCount": {
      "type": "integer",
      "minimum": 0
    },
    "detectedGraphCount": {
      "type": "integer",
      "minimum": 0
    },
    "graphCountScore": {
      "enum": [
        "PASS",
        "FAIL",
        "MISSING",
        "NOT_SCOREABLE"
      ]
    },
    "expectedLayoutClass": {
      "type": "string",
      "minLength": 1
    },
    "predictedLayoutClass": {
      "type": "string",
      "minLength": 1
    },
    "layoutClassScore": {
      "enum": [
        "PASS",
        "FAIL",
        "MISSING",
        "NOT_SCOREABLE"
      ]
    },
    "runtimeCalibrationClosure": {
      "$ref": "#/$defs/stageEvidence"
    },
    "calibrationClosureReport": {
      "type": "object"
    },
    "references": {
      "type": "object",
      "required": [
        "r8RecordPath",
        "r9RecordPath",
        "r10RecordPath"
      ],
      "additionalProperties": false,
      "properties": {
        "r8RecordPath": {
          "type": "string"
        },
        "r9RecordPath": {
          "type": "string"
        },
        "r10RecordPath": {
          "type": "string"
        }
      }
    },
    "failureClass": {
      "type": "string"
    },
    "firstFailingStage": {
      "type": "string"
    },
    "evidence": {
      "type": "object",
      "required": [
        "sourceImage",
        "recordSource",
        "artifactPaths"
      ],
      "additionalProperties": false,
      "properties": {
        "sourceImage": {
          "type": "string"
        },
        "recordSource": {
          "type": "string",
          "minLength": 1
        },
        "artifactPaths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "promotionDecision": {
      "enum": [
        "RUNTIME_CALIBRATION_REQUIRES_ANDROID_EVIDENCE_PACKAGE_PARITY",
        "PROMOTION_CANDIDATE_REQUIRES_RUNTIME_CALIBRATION_PARITY",
        "DO_NOT_PROMOTE_RESEARCH_ONLY"
      ]
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "stageEvidence": {
      "type": "object",
      "required": [
        "status",
        "available",
        "summary"
      ],
      "additionalProperties": false,
      "properties": {
        "status": {
          "enum": [
            "PASS",
            "REVIEW",
            "FAIL",
            "VALID",
            "INVALID",
            "MISSING",
            "NOT_RECORDED",
            "NOT_SCORED"
          ]
        },
        "available": {
          "type": "boolean"
        },
        "summary": {
          "type": "string"
        },
        "metrics": {
          "type": "object",
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "integer"
              },
              {
                "type": "boolean"
              },
              {
                "type": "string"
              }
            ]
          }
        }
      }
    }
  }
}
