{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chromalab.local/schemas/benchmark/stage123-parity-record.schema.json",
  "title": "ChromaLab Stage 1-3 Parity Record",
  "description": "Shadow/parity record for image preparation, graph discovery, and plotArea/layout output.",
  "type": "object",
  "required": [
    "schemaVersion",
    "recordId",
    "fixtureId",
    "mode",
    "sourceId",
    "sourceKind",
    "productionImpact",
    "runtimeReadiness",
    "expectedGraphCount",
    "detectedGraphCount",
    "graphCountScore",
    "expectedLayoutClass",
    "predictedLayoutClass",
    "layoutClassScore",
    "imagePreparation",
    "graphDiscovery",
    "plotAreaLayout",
    "evidence",
    "promotionDecision",
    "notes"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "chromalab.benchmark.stage123_parity_record.v1"
    },
    "recordId": {
      "type": "string",
      "minLength": 1
    },
    "caseId": {
      "type": "string"
    },
    "runId": {
      "type": "string"
    },
    "fixtureId": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": [
        "deterministic",
        "model_enabled",
        "pc_prototype",
        "annotation_upper_bound"
      ]
    },
    "sourceId": {
      "type": "string",
      "minLength": 1
    },
    "sourceKind": {
      "enum": [
        "ACTIVE_ANDROID_BASELINE",
        "PC_STAGE1_IMAGE_PREP_CANDIDATE",
        "RUST_STAGE1_IMAGE_PREP_PARITY_BRIDGE",
        "PC_PROTOTYPE",
        "ANNOTATION_UPPER_BOUND"
      ]
    },
    "productionImpact": {
      "const": "NONE_SHADOW_ONLY"
    },
    "runtimeReadiness": {
      "type": "string",
      "minLength": 1
    },
    "expectedGraphCount": {
      "type": "integer",
      "minimum": 0
    },
    "detectedGraphCount": {
      "type": "integer",
      "minimum": 0
    },
    "graphCountScore": {
      "enum": [
        "PASS",
        "FAIL",
        "MISSING",
        "NOT_SCOREABLE"
      ]
    },
    "expectedLayoutClass": {
      "type": "string",
      "minLength": 1
    },
    "predictedLayoutClass": {
      "type": "string",
      "minLength": 1
    },
    "layoutClassScore": {
      "enum": [
        "PASS",
        "FAIL",
        "MISSING",
        "NOT_SCOREABLE"
      ]
    },
    "imagePreparation": {
      "$ref": "#/$defs/stageEvidence"
    },
    "graphDiscovery": {
      "$ref": "#/$defs/stageEvidence"
    },
    "plotAreaLayout": {
      "$ref": "#/$defs/stageEvidence"
    },
    "failureClass": {
      "type": "string"
    },
    "firstFailingStage": {
      "type": "string"
    },
    "evidence": {
      "type": "object",
      "required": [
        "sourceImage",
        "recordSource",
        "artifactPaths"
      ],
      "additionalProperties": false,
      "properties": {
        "sourceImage": {
          "type": "string"
        },
        "recordSource": {
          "type": "string",
          "minLength": 1
        },
        "artifactPaths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "promotionDecision": {
      "enum": [
        "BASELINE_RECORD_ONLY",
        "DO_NOT_PROMOTE_RESEARCH_ONLY",
        "DO_NOT_PROMOTE_UPPER_BOUND_ONLY",
        "STAGE1_CANDIDATE_REQUIRES_STAGE2_PARITY",
        "PROMOTION_CANDIDATE_REQUIRES_RUST_OR_RUNTIME_PARITY"
      ]
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "stageEvidence": {
      "type": "object",
      "required": [
        "status",
        "available",
        "summary"
      ],
      "additionalProperties": false,
      "properties": {
        "status": {
          "enum": [
            "PASS",
            "REVIEW",
            "FAIL",
            "VALID",
            "INVALID",
            "MISSING",
            "NOT_RECORDED",
            "NOT_SCORED"
          ]
        },
        "available": {
          "type": "boolean"
        },
        "summary": {
          "type": "string"
        },
        "metrics": {
          "type": "object",
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "integer"
              },
              {
                "type": "boolean"
              },
              {
                "type": "string"
              }
            ]
          }
        }
      }
    }
  }
}
