set(CMAKE_BUILD_TYPE Release)
set(CMAKE_C_FLAGS "@CHROMALAB_HOST_COMPILER_BIN_FLAG@ -O2")
set(CMAKE_CXX_FLAGS "@CHROMALAB_HOST_COMPILER_BIN_FLAG@ -O2")
set(CMAKE_EXE_LINKER_FLAGS "@CHROMALAB_HOST_COMPILER_BIN_FLAG@")
set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY NEVER)
set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE NEVER)
set(CMAKE_C_COMPILER "@CHROMALAB_HOST_C_COMPILER_CMAKE@")
set(CMAKE_CXX_COMPILER "@CHROMALAB_HOST_CXX_COMPILER_CMAKE@")
set(CMAKE_MAKE_PROGRAM "@CHROMALAB_HOST_NINJA_CMAKE@" CACHE FILEPATH "" FORCE)
set(CMAKE_RUNTIME_OUTPUT_DIRECTORY "@CHROMALAB_RUNTIME_OUTPUT_DIR_CMAKE@")
